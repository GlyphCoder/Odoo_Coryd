# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ── Supabase Postgres ────────────────────────────────────
# Supabase → Connect → Connection string → URI (Session pooler).
# Replace [YOUR-PASSWORD] with your DB password.
DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=verify-full

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=S45JWLKJ43J3JJDJS2
JWT_EXPIRES_IN=7d

# ── Optional: enable Postgres RLS enforcement per request ─
ENABLE_RLS=false

# ── Free geo services (no API key needed) ────────────────
# Photon (geocoding/autocomplete) + OSRM (routing). Public demo servers below.
# Nominatim kept only as an optional fallback (it 403s generic User-Agents).
# For production/heavy use, self-host Photon + OSRM.
PHOTON_URL=https://photon.komoot.io
OSRM_URL=https://router.project-osrm.org
NOMINATIM_URL=https://nominatim.openstreetmap.org
GEO_USER_AGENT=carpool-hackathon/1.0 (contact@example.com)

# ── Payments (Razorpay test mode — optional) ─────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
